{
  "manifestVersion": 5,
  "id": "com.word_to_photoshop.panel",
  "name": "Word To Photoshop Panel",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "24.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "wordImportPanel",
      "label": {
        "default": "Word Import"
      },
      "minimumSize": {
        "width": 320,
        "height": 520
      },
      "maximumSize": {
        "width": 1400,
        "height": 2200
      },
      "preferredDockedSize": {
        "width": 380,
        "height": 800
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 860
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess"
  }
}
